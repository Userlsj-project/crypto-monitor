      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "crypto_postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  cp.timestamp AS time,\n  cp.price::float AS \"BTC 가격\"\nFROM coins_coinprice cp\nJOIN coins_coin c ON c.id = cp.coin_id\nWHERE c.symbol = 'BTCUSDT'\n  AND $__timeFilter(cp.timestamp)\nORDER BY cp.timestamp ASC",
          "refId": "A"
        }
      ],
      "title": "BTC/USDT 실시간 가격",
      "type": "timeseries"
    },
