        {
          "datasource": {
            "type": "postgres",
            "uid": "crypto_postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  al.created_at AS \"발동시각\",\n  c.symbol AS \"코인\",\n  al.triggered_price::float AS \"발동가격\",\n  CASE a.condition WHEN 'above' THEN '이상' ELSE '이하' END AS \"조건\",\n  a.target_price::float AS \"목표가\",\n  LEFT(al.ai_analysis, 100) AS \"AI분석\"\nFROM alerts_alertlog al\nJOIN alerts_alert a ON a.id = al.alert_id\nJOIN coins_coin c ON c.id = a.coin_id\nORDER BY al.created_at DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "알림 발동 로그",
