# ─────────────────────────────────────────
# Django 설정
# ─────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─────────────────────────────────────────
# PostgreSQL 설정
# ─────────────────────────────────────────
POSTGRES_DB=crypto_monitor
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────────────
# Redis 설정
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─────────────────────────────────────────
# Grafana 설정
# ─────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password
GRAFANA_PUBLIC_DASHBOARD_TOKEN=your-grafana-public-dashboard-token

# ─────────────────────────────────────────
# n8n 설정
# ─────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-n8n-password
N8N_WEBHOOK_URL=http://n8n:5678/webhook/crypto-alert

# ─────────────────────────────────────────
# Ollama / EXAONE 설정
# ─────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=exaone3.5:2.4b
OLLAMA_TIMEOUT=120

# ─────────────────────────────────────────
# SMTP 이메일 설정 (n8n 워크플로우용)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
ALERT_EMAIL_TO=recipient@gmail.com

# ─────────────────────────────────────────
# Binance API (공개 API - 키 불필요)
# ─────────────────────────────────────────
BINANCE_API_BASE_URL=https://api.binance.com
